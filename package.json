{
  "name": "rat-analytics",
  "version": "1.0.0",
  "description": "Privacy-First Analytics Platform - A lightweight, self-hosted analytics solution that prioritizes user privacy while providing valuable insights",
  "main": "server.js",
  "bin": {
    "rat-analytics": "./server.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:build": "docker build -t rat-analytics .",
    "docker:run": "docker run -p 3000:3000 -v $(pwd)/analytics.db:/app/analytics.db rat-analytics",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "security:audit": "npm audit",
    "security:check": "snyk test || echo 'Snyk not installed, run: npm install -g snyk'",
    "license:check": "npx license-checker --summary"
  },
  "keywords": [
    "analytics",
    "privacy-first",
    "self-hosted",
    "lightweight",
    "gdpr",
    "ccpa",
    "no-cookies",
    "open-source",
    "sqlite",
    "express"
  ],
  "author": "RAT Contributors (https://github.com/wenesay/rat)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wenesay/rat.git"
  },
  "bugs": {
    "url": "https://github.com/wenesay/rat/issues"
  },
  "homepage": "https://github.com/wenesay/rat#readme",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.7",
    "bcrypt": "^5.1.1",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "nodemon": "^3.0.2",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "@eslint/js": "^8.56.0",
    "globals": "^13.24.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "server.js",
      "snippet/*.js",
      "!node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true
    },
    "extends": [
      "eslint:recommended"
    ],
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "off",
      "prefer-const": "error",
      "no-var": "error"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2
  }
}
