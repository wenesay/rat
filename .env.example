# RAT Analytics Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# REQUIRED SETTINGS
# ==========================================

# Security: Generate a strong random string for session encryption
# You can generate one with: openssl rand -hex 32
SESSION_SECRET=your-super-secure-random-session-secret-here

# ==========================================
# OPTIONAL SETTINGS
# ==========================================

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS: Comma-separated list of allowed origins
# For production, specify your domain(s)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Database Configuration
# SQLite database path (default: ./analytics.db)
DATABASE_PATH=./analytics.db

# ==========================================
# PRODUCTION SETTINGS
# ==========================================

# In production, ensure these are set:
# - NODE_ENV=production
# - SESSION_SECRET with a strong random value
# - ALLOWED_ORIGINS with your actual domain(s)
# - HTTPS enabled (handled by reverse proxy like nginx/cloud provider)

# ==========================================
# SECURITY NOTES
# ==========================================
# - Never commit .env files to version control
# - Use different SESSION_SECRET for each environment
# - In production, use environment variables instead of .env files
# - Regularly rotate SESSION_SECRET

# ==========================================
# ADMIN SETUP (Optional)
# ==========================================

# Admin Setup (only set during initial setup)
SETUP_ADMIN=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeThisPassword123!

# Optional: External Services
# REDIS_URL=redis://localhost:6379
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# LOG_LEVEL=info